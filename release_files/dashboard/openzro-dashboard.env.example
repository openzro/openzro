# /etc/openzro-dashboard.env — runtime config for the openZro
# dashboard SPA. Edit this file, then run:
#
#   sudo /usr/share/openzro-dashboard/render-env.sh
#
# The script substitutes these values into the static bundle's
# placeholder strings. Re-run after every change.

# -----------------------------------------------------------------
# OIDC / Identity provider
# -----------------------------------------------------------------
AUTH_AUTHORITY=https://auth.example.com/realms/openzro
AUTH_CLIENT_ID=openzro-dashboard
AUTH_AUDIENCE=openzro-dashboard
AUTH_SUPPORTED_SCOPES=openid profile email groups

# Set to true if you're using Auth0 specifically. With self-hosted
# Dex / Keycloak / Authentik, set to false.
USE_AUTH0=false

# Optional — leave commented unless your IdP requires them.
# AUTH_CLIENT_SECRET=
# AUTH_REDIRECT_URI=/auth
# AUTH_SILENT_REDIRECT_URI=/silent-auth

# -----------------------------------------------------------------
# Management server endpoints
# -----------------------------------------------------------------
# Public REST endpoint (the same URL nginx proxies /api to).
OPENZRO_MGMT_API_ENDPOINT=https://openzro.example.com

# gRPC endpoint — usually the same host, optionally a separate
# subdomain if you've split TLS termination. Leave blank to derive
# from OPENZRO_MGMT_API_ENDPOINT.
OPENZRO_MGMT_GRPC_API_ENDPOINT=

# -----------------------------------------------------------------
# Tuning — usually leave defaults
# -----------------------------------------------------------------
OPENZRO_TOKEN_SOURCE=accessToken
OPENZRO_DRAG_QUERY_PARAMS=false

# /etc/nginx/sites-available/openzro-dashboard — example
# config for serving the openZro dashboard from a host nginx.
# Adapt the server_name, ssl_certificate paths, and upstream
# addresses to your environment. Symlink this file into
# /etc/nginx/sites-enabled/ and `nginx -s reload`.
#
# This config terminates TLS, serves the dashboard SPA, and
# reverse-proxies the management REST + gRPC paths and the
# signal gRPC path. Relay is L4 (UDP/TCP 33080) and goes
# directly through your firewall — NOT through this nginx.

upstream openzro_management_rest {
    server 127.0.0.1:33071;
    keepalive 32;
}

upstream openzro_management_grpc {
    server 127.0.0.1:33073;
    keepalive 32;
}

upstream openzro_signal_grpc {
    server 127.0.0.1:10000;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name openzro.example.com;

    # ACME challenge path for cert renewal — keep on port 80.
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # Everything else: redirect to HTTPS.
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name openzro.example.com;

    ssl_certificate     /etc/letsencrypt/live/openzro.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/openzro.example.com/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;

    client_max_body_size 32m;

    # Management gRPC. Path is the protobuf service FQN — must
    # match exactly so nginx routes the right requests to it.
    location /management.ManagementService {
        grpc_pass grpc://openzro_management_grpc;
        grpc_read_timeout 86400s;
        grpc_send_timeout 86400s;
        grpc_socket_keepalive on;
    }

    # Signal gRPC.
    location /signalexchange.SignalExchange {
        grpc_pass grpc://openzro_signal_grpc;
        grpc_read_timeout 86400s;
        grpc_send_timeout 86400s;
        grpc_socket_keepalive on;
    }

    # Management REST API.
    location /api {
        proxy_pass http://openzro_management_rest;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Dashboard SPA — Next.js static export. try_files makes
    # client-side routing work (deep-links don't 404).
    location / {
        root /usr/share/openzro-dashboard;
        try_files $uri $uri/ /index.html;
    }
}

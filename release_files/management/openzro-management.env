# Tunables for the openzro-management systemd service.
# Override per-host without touching /etc/systemd/system/openzro-management.service.

# Log level: trace | debug | info | warn | error
OPENZRO_LOG_LEVEL=info

# Store engine — set to "postgres" for HA / production. SQLite is
# the default but only supports a single management replica AND
# cannot be backed up without service downtime. See
# https://docs.openzro.io/selfhosted/storage for the trade-offs.
#
# When OPENZRO_STORE_ENGINE=postgres, the DSN below is mandatory.
# Format: postgres://user:pass@host:5432/dbname?sslmode=disable
#
# OPENZRO_STORE_ENGINE=postgres
# OPENZRO_STORE_ENGINE_POSTGRES_DSN=postgres://openzro:secret@db.example.com/openzro?sslmode=require

# Same for the activity / audit event store (a SECOND backend the
# management binary uses for who-did-what logging). Defaults to
# sqlite under /var/lib/openzro/management/. Switch to postgres
# alongside the primary store for HA.
#
# OZ_ACTIVITY_EVENT_STORE_ENGINE=postgres
# OZ_ACTIVITY_EVENT_POSTGRES_DSN=postgres://openzro:secret@db.example.com/openzro?sslmode=require

# Dex gRPC integration (runtime connector CRUD via dashboard's
# Settings → Authentication Providers). Required if you want to
# add Keycloak / Okta / Entra connectors via the UI without
# manually editing dex.config.yaml.
#
# OPENZRO_DEX_GRPC_ADDR=dex.openzro.example.com:5557
# OPENZRO_DEX_GRPC_INSECURE=true   # only if dex is on loopback or trusted LAN
# OPENZRO_DEX_GRPC_CA_CERT=/etc/openzro/dex-ca.crt
# OPENZRO_DEX_GRPC_CLIENT_CERT=/etc/openzro/dex-client.crt
# OPENZRO_DEX_GRPC_CLIENT_KEY=/etc/openzro/dex-client.key

# Tunables for the openzro-signal systemd service.

# Log level: trace | debug | info | warn | error
OPENZRO_LOG_LEVEL=info

# Signal is stateless — peers connect, exchange WireGuard handshakes
# through it, and disconnect. No persistent storage to wire.
# For HA, run multiple replicas behind a TCP load balancer (clients
# fall over automatically via management's Signal.URI rotation).

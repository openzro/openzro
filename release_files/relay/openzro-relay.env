# Tunables for the openzro-relay systemd service.

# Log level: trace | debug | info | warn | error
OZ_LOG_LEVEL=info

# REQUIRED: TCP listen socket inside the host. Most operators leave
# this at :33080 and front it with a public LB / iptables forward.
OZ_LISTEN_ADDRESS=:33080

# REQUIRED: the public address peers connect to (DNS hostname +
# port, with rel:// or rels:// scheme). MUST be set — clients fail
# to dial the relay if this is wrong. rels:// requires TLS material;
# for plaintext (lab / trusted LAN) use rel://.
#
# OZ_EXPOSED_ADDRESS=rel://relay.openzro.example.com:33080

# REQUIRED: Shared HMAC secret used to mint per-client credentials.
# MUST match the management.json Relay.Secret on the management
# host(s). Generate with:
#   openssl rand -base64 32
#
# OZ_AUTH_SECRET=replace-me-with-32-byte-base64

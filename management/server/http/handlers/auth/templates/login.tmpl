<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Sign in · openZro</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="color-scheme" content="light dark">
<meta name="referrer" content="strict-origin-when-cross-origin">
<style>
  :root {
    --oz-violet-50:  #f5f3ff;
    --oz-violet-100: #ede9fe;
    --oz-violet-200: #ddd6fe;
    --oz-violet-300: #c4b5fd;
    --oz-violet-400: #a78bfa;
    --oz-violet-500: #8b5cf6;
    --oz-violet-600: #7c3aed;
    --oz-violet-700: #6d28d9;
    --oz-violet-900: #4c1d95;
    --oz-ink:    #0f0a1f;
    --oz-paper:  #faf9fc;
    --oz-bg:        #ffffff;
    --oz-bg-soft:   var(--oz-violet-50);
    --oz-text:      var(--oz-ink);
    --oz-text-muted: #6b7280;
    --oz-border:    var(--oz-violet-200);
    --oz-primary:       var(--oz-violet-600);
    --oz-primary-hover: var(--oz-violet-700);
    --oz-z-color:       var(--oz-violet-600);
    --oz-sans: 'Geist', -apple-system, system-ui, 'Segoe UI', Roboto, sans-serif;
    --oz-mono: 'JetBrains Mono', ui-monospace, monospace;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --oz-bg:        var(--oz-ink);
      --oz-bg-soft:   #1a1330;
      --oz-text:      #ffffff;
      --oz-text-muted: #9ca3af;
      --oz-border:    #2d2347;
      --oz-z-color:   var(--oz-violet-400);
      --oz-primary:       var(--oz-violet-500);
      --oz-primary-hover: var(--oz-violet-400);
    }
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    font-family: var(--oz-sans);
    color: var(--oz-text);
    background: var(--oz-bg);
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 24px;
    line-height: 1.55;
  }
  .oz-login {
    width: 100%;
    max-width: 420px;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 28px;
  }
  .oz-login__brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }
  .oz-login__brand svg {
    width: 56px;
    height: 56px;
  }
  .oz-wordmark {
    font-family: var(--oz-sans);
    font-weight: 600;
    font-size: 24px;
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--oz-text);
  }
  .oz-wordmark .oz-z {
    color: var(--oz-z-color);
    font-weight: 700;
  }
  .oz-login__title {
    margin: 0;
    text-align: center;
    font-size: 18px;
    font-weight: 500;
    color: var(--oz-text-muted);
    letter-spacing: -0.01em;
  }
  .oz-login__providers {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .oz-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 12px 18px;
    border-radius: 10px;
    border: 1px solid var(--oz-border);
    background: var(--oz-bg-soft);
    color: var(--oz-text);
    font-family: var(--oz-sans);
    font-weight: 500;
    font-size: 15px;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s, transform 0.05s;
  }
  .oz-btn:hover {
    background: var(--oz-violet-100);
    border-color: var(--oz-violet-300);
  }
  .oz-btn:active { transform: translateY(1px); }
  @media (prefers-color-scheme: dark) {
    .oz-btn:hover { background: var(--oz-violet-900); border-color: var(--oz-violet-700); }
  }
  .oz-btn__logo {
    width: 18px; height: 18px; flex: 0 0 18px;
  }
  .oz-login__empty {
    text-align: center;
    padding: 24px 16px;
    border: 1px dashed var(--oz-border);
    border-radius: 10px;
    background: var(--oz-bg-soft);
    color: var(--oz-text-muted);
    font-size: 14px;
  }
  .oz-login__empty strong { color: var(--oz-text); }
  .oz-login__footer {
    margin: 0;
    text-align: center;
    font-family: var(--oz-mono);
    font-size: 12px;
    color: var(--oz-text-muted);
    letter-spacing: 0.04em;
  }
  .oz-login__error {
    padding: 10px 14px;
    border-radius: 8px;
    background: #fee2e2;
    border: 1px solid #fecaca;
    color: #991b1b;
    font-size: 14px;
  }
  @media (prefers-color-scheme: dark) {
    .oz-login__error {
      background: #2a0e16; border-color: #7f1d1d; color: #fca5a5;
    }
  }
</style>
</head>
<body>
  <main class="oz-login">
    <div class="oz-login__brand">
      {{ozIcon}}
      <span class="oz-wordmark">open<span class="oz-z">Z</span>ro</span>
    </div>
    <h1 class="oz-login__title">Sign in to continue</h1>
    {{if .Error}}
      <div class="oz-login__error">{{.Error}}</div>
    {{end}}
    {{if .Providers}}
      <ul class="oz-login__providers">
        {{range .Providers}}
          <li>
            <a class="oz-btn" href="{{startURL .ID $.ReturnTo}}">
              {{if .LogoURL}}
                <img class="oz-btn__logo" src="{{.LogoURL}}" alt="" aria-hidden="true">
              {{end}}
              <span>Sign in with {{.Label}}</span>
            </a>
          </li>
        {{end}}
      </ul>
    {{else}}
      <div class="oz-login__empty">
        <p>No authentication providers configured.</p>
        <p>Ask your administrator to add one in
        <strong>Settings &rarr; Authentication Providers</strong>.</p>
      </div>
    {{end}}
    <p class="oz-login__footer">openZro &middot; zero-trust mesh networking</p>
  </main>
</body>
</html>

## Most settings are being done automatically with the sourced variables from setup.env, but you can edit if you need some customization

# Management API

# Management API port
OPENZRO_MGMT_API_PORT=${OPENZRO_MGMT_API_PORT:-33073}
# Management API endpoint address, used by the Dashboard
OPENZRO_MGMT_API_ENDPOINT=https://$OPENZRO_DOMAIN:$OPENZRO_MGMT_API_PORT
# Management Certificate file path. These are generated by the Dashboard container
OPENZRO_LETSENCRYPT_DOMAIN=$OPENZRO_DOMAIN
OPENZRO_MGMT_API_CERT_FILE="/etc/letsencrypt/live/$OPENZRO_LETSENCRYPT_DOMAIN/fullchain.pem"
# Management Certificate key file path.
OPENZRO_MGMT_API_CERT_KEY_FILE="/etc/letsencrypt/live/$OPENZRO_LETSENCRYPT_DOMAIN/privkey.pem"
# By default Management single account mode is enabled and domain set to $OPENZRO_DOMAIN, you may want to set this to your user's email domain
OPENZRO_MGMT_SINGLE_ACCOUNT_MODE_DOMAIN=$OPENZRO_DOMAIN
OPENZRO_MGMT_DNS_DOMAIN=${OPENZRO_MGMT_DNS_DOMAIN:-openzro.selfhosted}
OPENZRO_MGMT_IDP_SIGNKEY_REFRESH=${OPENZRO_MGMT_IDP_SIGNKEY_REFRESH:-false}
OPENZRO_MGMT_DISABLE_DEFAULT_POLICY=${OPENZRO_MGMT_DISABLE_DEFAULT_POLICY:-false}

# Signal
OPENZRO_SIGNAL_PROTOCOL="http"
OPENZRO_SIGNAL_PORT=${OPENZRO_SIGNAL_PORT:-10000}

# Relay
OPENZRO_RELAY_DOMAIN=${OPENZRO_RELAY_DOMAIN:-$OPENZRO_DOMAIN}
OPENZRO_RELAY_PORT=${OPENZRO_RELAY_PORT:-33080}
OPENZRO_RELAY_ENDPOINT=${OPENZRO_RELAY_ENDPOINT:-rel://$OPENZRO_RELAY_DOMAIN:$OPENZRO_RELAY_PORT}
# Relay auth secret
OPENZRO_RELAY_AUTH_SECRET=

# Turn
TURN_DOMAIN=${OPENZRO_TURN_DOMAIN:-$OPENZRO_DOMAIN}

OPENZRO_TURN_EXTERNAL_IP=${OPENZRO_TURN_EXTERNAL_IP}

# Turn credentials
# User
TURN_USER=self
# Password. If empty, the configure.sh will generate one with openssl
TURN_PASSWORD=
# Min port
TURN_MIN_PORT=${TURN_MIN_PORT:-49152}
# Max port
TURN_MAX_PORT=${TURN_MAX_PORT:-65535}

VOLUME_PREFIX="openzro-"
MGMT_VOLUMESUFFIX="mgmt"
SIGNAL_VOLUMESUFFIX="signal"
LETSENCRYPT_VOLUMESUFFIX="letsencrypt"

OPENZRO_AUTH_DEVICE_AUTH_PROVIDER="none"
OPENZRO_AUTH_DEVICE_AUTH_AUDIENCE=${OPENZRO_AUTH_DEVICE_AUTH_AUDIENCE:-$OPENZRO_AUTH_AUDIENCE}
OPENZRO_AUTH_DEVICE_AUTH_SCOPE=${OPENZRO_AUTH_DEVICE_AUTH_SCOPE:-openid}
OPENZRO_AUTH_DEVICE_AUTH_USE_ID_TOKEN=${OPENZRO_AUTH_DEVICE_AUTH_USE_ID_TOKEN:-false}


OPENZRO_DISABLE_ANONYMOUS_METRICS=${OPENZRO_DISABLE_ANONYMOUS_METRICS:-false}
OPENZRO_TOKEN_SOURCE=${OPENZRO_TOKEN_SOURCE:-accessToken}

# PKCE authorization flow
OPENZRO_AUTH_PKCE_REDIRECT_URL_PORTS=${OPENZRO_AUTH_PKCE_REDIRECT_URL_PORTS:-"53000"}
OPENZRO_AUTH_PKCE_USE_ID_TOKEN=${OPENZRO_AUTH_PKCE_USE_ID_TOKEN:-false}
OPENZRO_AUTH_PKCE_DISABLE_PROMPT_LOGIN=${OPENZRO_AUTH_PKCE_DISABLE_PROMPT_LOGIN:-false}
OPENZRO_AUTH_PKCE_LOGIN_FLAG=${OPENZRO_AUTH_PKCE_LOGIN_FLAG:-0}
OPENZRO_AUTH_PKCE_AUDIENCE=$OPENZRO_AUTH_AUDIENCE

# Dashboard

# The default setting is to transmit the audience to the IDP during authorization. However,
# if your IDP does not have this capability, you can turn this off by setting it to false.
OPENZRO_DASH_AUTH_USE_AUDIENCE=${OPENZRO_DASH_AUTH_USE_AUDIENCE:-true}
OPENZRO_DASH_AUTH_AUDIENCE=$OPENZRO_AUTH_AUDIENCE

# Store config
OPENZRO_STORE_CONFIG_ENGINE=${OPENZRO_STORE_CONFIG_ENGINE:-"sqlite"}

# Image tags
OPENZRO_DASHBOARD_TAG=${OPENZRO_DASHBOARD_TAG:-"latest"}
OPENZRO_SIGNAL_TAG=${OPENZRO_SIGNAL_TAG:-"latest"}
OPENZRO_MANAGEMENT_TAG=${OPENZRO_MANAGEMENT_TAG:-"latest"}
COTURN_TAG=${COTURN_TAG:-"latest"}
OPENZRO_RELAY_TAG=${OPENZRO_RELAY_TAG:-"latest"}

# exports
export OPENZRO_DOMAIN
export OPENZRO_TURN_DOMAIN
export OPENZRO_AUTH_CLIENT_ID
export OPENZRO_AUTH_CLIENT_SECRET
export OPENZRO_AUTH_AUDIENCE
export OPENZRO_AUTH_AUTHORITY
export OPENZRO_USE_AUTH0
export OPENZRO_AUTH_SUPPORTED_SCOPES
export OPENZRO_AUTH_JWT_CERTS
export OPENZRO_LETSENCRYPT_EMAIL
export OPENZRO_MGMT_API_PORT
export OPENZRO_MGMT_API_ENDPOINT
export OPENZRO_LETSENCRYPT_DOMAIN
export OPENZRO_MGMT_API_CERT_FILE
export OPENZRO_MGMT_API_CERT_KEY_FILE
export OPENZRO_AUTH_DEVICE_AUTH_PROVIDER
export OPENZRO_AUTH_DEVICE_AUTH_CLIENT_ID
export OPENZRO_AUTH_OIDC_CONFIGURATION_ENDPOINT
export OPENZRO_AUTH_REDIRECT_URI
export OPENZRO_AUTH_SILENT_REDIRECT_URI
export TURN_DOMAIN
export TURN_USER
export TURN_PASSWORD
export TURN_MIN_PORT
export TURN_MAX_PORT
export VOLUME_PREFIX
export MGMT_VOLUMESUFFIX
export SIGNAL_VOLUMESUFFIX
export LETSENCRYPT_VOLUMESUFFIX
export OPENZRO_DISABLE_ANONYMOUS_METRICS
export OPENZRO_MGMT_SINGLE_ACCOUNT_MODE_DOMAIN
export OPENZRO_MGMT_DNS_DOMAIN
export OPENZRO_MGMT_IDP_SIGNKEY_REFRESH
export OPENZRO_SIGNAL_PROTOCOL
export OPENZRO_SIGNAL_PORT
export OPENZRO_AUTH_USER_ID_CLAIM
export OPENZRO_AUTH_DEVICE_AUTH_AUDIENCE
export OPENZRO_TOKEN_SOURCE
export OPENZRO_AUTH_DEVICE_AUTH_SCOPE
export OPENZRO_AUTH_DEVICE_AUTH_USE_ID_TOKEN
export OPENZRO_AUTH_PKCE_AUTHORIZATION_ENDPOINT
export OPENZRO_AUTH_PKCE_USE_ID_TOKEN
export OPENZRO_AUTH_PKCE_DISABLE_PROMPT_LOGIN
export OPENZRO_AUTH_PKCE_LOGIN_FLAG
export OPENZRO_AUTH_PKCE_AUDIENCE
export OPENZRO_DASH_AUTH_USE_AUDIENCE
export OPENZRO_DASH_AUTH_AUDIENCE
export OPENZRO_STORE_CONFIG_ENGINE
export OPENZRO_DASHBOARD_TAG
export OPENZRO_SIGNAL_TAG
export OPENZRO_MANAGEMENT_TAG
export COTURN_TAG
export OPENZRO_TURN_EXTERNAL_IP
export OPENZRO_RELAY_DOMAIN
export OPENZRO_RELAY_PORT
export OPENZRO_RELAY_ENDPOINT
export OPENZRO_RELAY_AUTH_SECRET
export OPENZRO_RELAY_TAG
export OPENZRO_MGMT_DISABLE_DEFAULT_POLICY

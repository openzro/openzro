## example file, you can copy this file to setup.env and update its values
##
# Dashboard domain. e.g. app.mydomain.com
OPENZRO_DOMAIN=$CI_OPENZRO_DOMAIN
# e.g. https://dev-24vkclam.us.auth0.com/ or https://YOUR-KEYCLOAK-HOST:8080/realms/openzro
OPENZRO_AUTH_OIDC_CONFIGURATION_ENDPOINT="https://example.eu.auth0.com/.well-known/openid-configuration"
# e.g. openzro-client
OPENZRO_AUTH_CLIENT_ID=$CI_OPENZRO_AUTH_CLIENT_ID
OPENZRO_AUTH_SUPPORTED_SCOPES=$CI_OPENZRO_AUTH_SUPPORTED_SCOPES
OPENZRO_AUTH_CLIENT_SECRET=$CI_OPENZRO_AUTH_CLIENT_SECRET
# indicates whether to use Auth0 or not: true or false
OPENZRO_USE_AUTH0=$CI_OPENZRO_USE_AUTH0
OPENZRO_AUTH_AUDIENCE=$CI_OPENZRO_AUTH_AUDIENCE
# e.g. hello@mydomain.com
OPENZRO_LETSENCRYPT_EMAIL=""
OPENZRO_AUTH_REDIRECT_URI="/peers"
OPENZRO_DISABLE_LETSENCRYPT=true
OPENZRO_TOKEN_SOURCE="idToken"
OPENZRO_AUTH_DEVICE_AUTH_AUDIENCE="super"
OPENZRO_AUTH_USER_ID_CLAIM="email"
OPENZRO_AUTH_DEVICE_AUTH_SCOPE="openid email"
OPENZRO_MGMT_IDP=$CI_OPENZRO_MGMT_IDP
OPENZRO_IDP_MGMT_CLIENT_ID=$CI_OPENZRO_IDP_MGMT_CLIENT_ID
OPENZRO_IDP_MGMT_CLIENT_SECRET=$CI_OPENZRO_IDP_MGMT_CLIENT_SECRET
OPENZRO_SIGNAL_PORT=12345
OPENZRO_STORE_CONFIG_ENGINE=$CI_OPENZRO_STORE_CONFIG_ENGINE
OPENZRO_MGMT_IDP_SIGNKEY_REFRESH=$CI_OPENZRO_MGMT_IDP_SIGNKEY_REFRESH
OPENZRO_TURN_EXTERNAL_IP=1.2.3.4
OPENZRO_RELAY_PORT=33445
OPENZRO_AUTH_PKCE_DISABLE_PROMPT_LOGIN=true
OPENZRO_AUTH_PKCE_LOGIN_FLAG=0
OPENZRO_MGMT_DISABLE_DEFAULT_POLICY=$CI_OPENZRO_MGMT_DISABLE_DEFAULT_POLICY
